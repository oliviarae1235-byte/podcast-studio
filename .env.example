# ============ SCRIPT WRITER (LLM) ============
# Free option: Groq (OpenAI-compatible, no credit card). Sign up at console.groq.com
LLM_PROVIDER=openai
OPENAI_API_KEY=your_groq_or_openai_key_here
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_BASE_URL=https://api.groq.com/openai/v1
# For real OpenAI instead: drop OPENAI_BASE_URL and use OPENAI_MODEL=gpt-4o-mini
# For Anthropic: set LLM_PROVIDER=anthropic and ANTHROPIC_API_KEY + ANTHROPIC_MODEL

# ============ VOICES ============
# Local Chatterbox (free, runs on your Mac) is the default and needs NO key.
LOCAL_TTS_URL=http://127.0.0.1:5050

# ElevenLabs is OPTIONAL. Leave blank to run 100% free/local.
# If you add a key, its catalog voices show up alongside the local ones.
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_multilingual_v2

# Replicate is OPTIONAL — runs the SAME Chatterbox model on a cloud GPU (much faster
# than local). Get a token at https://replicate.com/account/api-tokens. Leave blank
# to skip. When set, a built-in Replicate voice plus any Replicate clones you create
# appear in the voice list and can be assigned to Host A/B.
REPLICATE_API_TOKEN=
# Override the hosted model if needed (default shown):
# REPLICATE_MODEL=resemble-ai/chatterbox-multilingual

# Server port
PORT=3000

# ============ ACCESS CONTROL (optional — for hosting it publicly) ============
# Leave ALL of these blank for normal local use: no login page is shown.
# If you expose the app to the internet, set APP_PASSWORD (and optionally
# Google Sign-In) so only you can reach your episodes and voices.
APP_PASSWORD=
# Any long random string; keeps you signed in across server restarts.
SESSION_SECRET=
# Google Sign-In (optional): create an OAuth "Web application" Client ID at
# console.cloud.google.com and add your site's https URL as an authorized
# JavaScript origin, then paste the Client ID here.
GOOGLE_CLIENT_ID=
# Restrict who may create an account (comma-separated emails). Leave blank to
# let ANYONE sign up — each account gets its own private episodes and voices.
ALLOWED_EMAILS=
# Admin account(s): also see episodes/voices created before accounts existed,
# can use APP_PASSWORD to sign in, and skip the per-user queue limit.
ADMIN_EMAILS=
